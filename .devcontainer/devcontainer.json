{
  "name": "CompareTaBanque",
  "image": "mcr.microsoft.com/devcontainers/universal:latest",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "18"
    }
  },
  "postCreateCommand": "cd frontend && npm install",
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "Frontend Dev Server",
      "onAutoForward": "notify"
    }
  }
}
