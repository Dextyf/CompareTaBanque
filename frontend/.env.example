# ============================================================
# VARIABLES D'ENVIRONNEMENT — CompareTaBanque
# Copiez ce fichier en .env et renseignez vos valeurs réelles.
# ⚠️  Ne jamais committer le fichier .env (déjà dans .gitignore)
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://[votre-project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...   # clé "anon / public"

# ── N8N (optionnel — automatisation des workflows leads) ──────
# URL du webhook N8N déclenchant l'envoi de leads aux banques
VITE_N8N_WEBHOOK_URL=https://[votre-instance-n8n]/webhook/[uuid]

# ============================================================
# SECRETS GITHUB ACTIONS (à configurer dans :
#   GitHub → votre repo → Settings → Secrets and variables → Actions)
# ============================================================
#
# Reprendre les 3 variables ci-dessus PLUS :
#
#   FTP_SERVER    → fourni par Hostinger (ex: ftp.votredomaine.com)
#   FTP_USERNAME  → fourni par Hostinger
#   FTP_PASSWORD  → fourni par Hostinger
#
# Ces variables ne sont PAS dans ce fichier .env car elles
# n'ont pas besoin d'exister en local — uniquement sur GitHub.
# ============================================================
